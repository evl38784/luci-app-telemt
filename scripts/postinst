#!/bin/sh
echo ""
echo "================================================================="
echo " Installing luci-app-telemt WebUI (v3.3.16)"
echo "================================================================="

# Checking for standalone telemt
if [ ! -x "/usr/bin/telemt" ]; then
    echo " WARNING: Headless telemt binary was NOT found!"
    echo " The WebUI requires the core daemon to function properly."
    echo " Please download and install the core IPK/APK from:"
    echo " https://github.com/Medvedolog/telemt-openwrt/"
else
    echo " OK: telemt binary found."
    echo " REMINDER: This WebUI is optimized for telemt core version >= 3.3.16."
    echo " You can always download the latest core IPK/APK from:"
    echo " https://github.com/Medvedolog/telemt-openwrt/"
fi

echo "================================================================="
echo " Clearing LuCI cache and restarting RPCD..."
rm -f /tmp/luci-indexcache /tmp/luci-modulecache/* 2>/dev/null
/etc/init.d/rpcd restart 2>/dev/null
exit 0
